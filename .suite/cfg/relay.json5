{
  // Enable inbound relay (LMTP relay to Dovecot is configured separately).
  enabled: false,

  // Enable outbound relay.
  outboundEnabled: true,

  // Enable outbound MX relay.
  // When enabled, the server will perform MX lookups for recipient domains instead of using inbound relay host.
  outboundMxEnabled: true,

  // Disable relay by magic header feature.
  disableRelayHeader: true,

  // Bounce email if relay fails.
  bounce: true,

  // Retry count for outbound relay (Default: 30).
  maxRetryCount: 30

  // IP pools for weighted outbound bind address selection.
  // Omit or leave empty to skip binding (default OS selection).
  // ipPools: [
  //   {
  //     name: "default",
  //     default: true,
  //     addresses: [
  //       { ip: "10.0.0.1", weight: 10 },
  //       { ip: "10.0.0.2", weight: 5 }
  //     ]
  //   }
  // ]
}