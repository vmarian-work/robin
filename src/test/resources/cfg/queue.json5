{
  // Queue service start delay (in seconds).
  startDelaySeconds: 10,

  // Queue housekeeping interval for releasing expired claims (in seconds).
  housekeepingIntervalSeconds: 30,

  // Maximum number of messages to claim per dispatcher batch.
  maxClaimBatch: 10,

  // MapDB backend configuration (disabled for tests - using in-memory instead).
  queueMapDB: {
    enabled: false
  },

  // Redis backend configuration (disabled for tests).
  queueRedis: {
    enabled: false
  },

  // MariaDB backend configuration (disabled for tests).
  queueMariaDB: {
    enabled: false
  },

  // PostgreSQL backend configuration (disabled for tests).
  queuePgSQL: {
    enabled: false
  }
}
