{
  // Queue configuration for performance testing.
  // Tuned for aggressive dequeue processing under high load.
  enabled: true,
  startDelaySeconds: 1,
  housekeepingIntervalSeconds: 1,
  workerThreads: 32,
  maxInFlight: 32,
  maxClaimBatch: 64,

  queueMapDB: {
    enabled: false
  },

  queuePgSQL: {
    enabled: true,
    jdbcUrl: "jdbc:postgresql://postgres-backend:5432/robin",
    username: "robin",
    password: "robin",
    tableName: "relay_queue"
  }
}
