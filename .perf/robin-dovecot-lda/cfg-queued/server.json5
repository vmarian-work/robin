{
  // Performance test Robin MTA server configuration.
  hostname: "perf-robin",
  bind: "::",
  smtpPort: 25,
  securePort: 0,
  submissionPort: 0,

  smtpConfig: {
    backlog: 1000,
    minimumPoolSize: 50,
    maximumPoolSize: 350,
    threadKeepAliveTime: 180,
    transactionsLimit: 1000,
    recipientsLimit: 100,
    envelopeLimit: 1000,
    messageSizeLimit: 10485760,
    errorLimit: 10,
    dosProtectionEnabled: false
  },

  auth: false,
  starttls: false,
  chunking: true,

  service: {
    port: 8080,
    authType: "none"
  },

  api: {
    port: 8090,
    authType: "none"
  },

  dnsNegativeTtl: 300
}
