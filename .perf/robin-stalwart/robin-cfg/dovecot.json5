{
  authSql: {
    enabled: false,
    usersQuery: "SELECT email FROM users",
    domainQuery: "",
    aliasQuery: ""
  },

  saveLmtp: {
    enabled: true,
    inline: false,
    servers: ["lmtp-backend"],
    port: 24,
    timeout: 30000,
    tls: false,

    connectionPoolSize: 64,
    connectionPoolTimeoutSeconds: 180,
    connectionIdleTimeoutSeconds: 270,
    connectionMaxLifetimeSeconds: 1800,
    // Stalwart starts returning 452 after about 10 messages per LMTP session.
    connectionMaxMessagesPerConnection: 10
  }
}
